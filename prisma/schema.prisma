datasource db {
  // Prisma 7: connection URLs live in prisma.config.ts, not here.
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  // Profile row. id equals the Supabase auth.users UUID (set by the auth trigger
  // in supabase/migrations on signup) — no self-generated default. Credentials
  // (password) live in Supabase auth, never here.
  id             String   @id
  name           String
  email          String   @unique
  monthlyIncome  Float?
  currency       String   @default("CAD")
  budgetTarget   Float?
  budgetPlan     String?  @default("50-30-20") // Needs/Wants/Savings plan id (see lib/constants BUDGET_PLANS)
  accent         String?  // Brand-kit accent (oklch); null = the default evergreen
  onboardingDone Boolean  @default(false)
  // otterfund staff flag. Gates the internal /dev tools (brand kit, AI usage,
  // plan-preview switcher). Set manually in the DB — never exposed in product UI.
  isAdmin        Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Billing (Stripe). The webhook is the source of truth for these — checkout
  // only kicks off the flow. `plan` is the entitlement tier (see lib/plans
  // PLAN_TIERS): free | standard | pro. `planStatus` mirrors the Stripe
  // subscription status (active | trialing | past_due | canceled | ...).
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  plan                 String    @default("free")
  planStatus           String?
  planInterval         String?   // month | year
  planRenewsAt         DateTime? // current_period_end — when it renews or lapses

  accounts         Account[]
  transactions     Transaction[]
  categories       Category[]
  goals            Goal[]
  subscriptions    Subscription[]
  bills            Bill[]
  budgets          Budget[]
  insights         Insight[]
  bankStatements   BankStatement[]
  goalAllocations  GoalAllocation[]
  plaidItems       PlaidItem[]
  plaidLinkEvents  PlaidLinkEvent[]
  advisorChats     AdvisorConversation[]
  advisorMessages  AdvisorMessage[]
  investments      Investment[]
  aiUsageEvents    AiUsageEvent[]
}

model Account {
  id        String   @id @default(cuid())
  userId    String
  name      String
  type      String
  number    String?
  balance   Float
  gradient  String?
  // Locally hidden: kept synced, but dropped from net worth and totals. Lets a
  // user omit one account of a Plaid item without unlinking the whole bank.
  excluded  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Plaid sync (null for manually-created accounts)
  plaidItemId    String?
  plaidAccountId String?   @unique
  institution    String?
  mask           String?
  syncedAt       DateTime?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  plaidItem    PlaidItem?    @relation(fields: [plaidItemId], references: [id], onDelete: Cascade)
  investments  Investment[]
}

// One connected bank login (Plaid "Item"). Holds the encrypted access token
// and the /transactions/sync cursor. Removing it cascades its accounts (and
// their transactions).
model PlaidItem {
  id              String    @id @default(cuid())
  userId          String
  itemId          String    @unique
  accessToken     String
  institutionId   String?
  institutionName String?
  cursor          String?
  status          String    @default("active") // active | login_required | error
  error           String?
  lastSyncedAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accounts Account[]

  @@index([userId])
}

// Durable log of successful bank links — kept even after an Item is disconnected
// so connect/disconnect churn can be rate-limited (each link creates a billable
// Plaid Item). Pruned to a rolling window.
model PlaidLinkEvent {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Category {
  id        String  @id @default(cuid())
  userId    String
  name      String
  icon      String?
  color     String?
  isDefault Boolean @default(false)

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  budgets       Budget[]
  subscriptions Subscription[]

  @@unique([userId, name])
}

model Transaction {
  id            String   @id @default(cuid())
  userId        String
  accountId     String?
  categoryId    String?
  name          String
  amount        Float
  date          DateTime
  icon          String?
  color         String?
  isRecurring   Boolean  @default(false)
  recurringFlag String?
  source        String   @default("manual")
  statementId   String?
  externalId    String?  @unique // Plaid transaction_id (null for manual entries)
  pending       Boolean  @default(false)
  createdAt     DateTime @default(now())

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  account   Account?       @relation(fields: [accountId], references: [id])
  category  Category?      @relation(fields: [categoryId], references: [id])
  statement BankStatement? @relation(fields: [statementId], references: [id])
}

model Goal {
  id        String    @id @default(cuid())
  userId    String
  name      String
  emoji     String?
  saved     Float     @default(0)
  target    Float
  priority  Float     @default(0)
  color     String?
  deadline  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  allocations GoalAllocation[]
}

model GoalAllocation {
  id        String   @id @default(cuid())
  userId    String
  goalId    String
  month     Int
  year      Int
  amount    Float
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([userId, goalId, month, year])
}

model Subscription {
  id                  String    @id @default(cuid())
  userId              String
  categoryId          String?
  name                String
  amount              Float
  previousAmount      Float?
  cycle               String
  icon                String?
  color               String?
  domain              String?
  isActive            Boolean   @default(true)
  detectedAt          DateTime?
  lastTransactionDate DateTime?
  confirmedByUser     Boolean   @default(false)
  createdAt           DateTime  @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id])
}

// A single investment holding — a position the user holds (stock, ETF, crypto,
// bond, cash, …), optionally linked to the Account that custodies it. `domain`
// mirrors Subscription.domain: the resolved company domain used to fetch a real
// logo (see lib/merchant/resolve). `value` is the current market value the user
// maintains; `costBasis` (optional) enables gain/loss; `quantity` (optional) is
// units/shares held.
model Investment {
  id         String   @id @default(cuid())
  userId     String
  accountId  String?
  name       String
  symbol     String?
  assetClass String
  value      Float
  costBasis  Float?
  quantity   Float?
  domain     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account? @relation(fields: [accountId], references: [id])

  @@index([userId])
}

// Universal, cross-user merchant cache. Keyed by a normalized merchant name so
// a given merchant is resolved to a company/domain ONCE (via the seed dictionary
// or a Haiku call) and reused by every user forever. `domain` null means
// "resolved but no domain found"; `isCompany` false marks a generic
// pattern/payment string that isn't a real company (so we skip the logo).
model Merchant {
  id            String   @id @default(cuid())
  normalizedKey String   @unique
  displayName   String
  domain        String?
  isCompany     Boolean  @default(true)
  source        String   @default("claude") // "dictionary" | "claude" | "manual"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Bill {
  id        String   @id @default(cuid())
  userId    String
  name      String
  amount    Float
  dueDate   DateTime
  isUrgent  Boolean  @default(false)
  isPaid    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Budget {
  id         String @id @default(cuid())
  userId     String
  categoryId String
  amount     Float
  month      Int
  year       Int

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@unique([userId, categoryId, month, year])
}

model Insight {
  id        String   @id @default(cuid())
  userId    String
  tag       String
  body      String
  tagColor  String?
  tagBg     String?
  // The data lever this insight is about, so the card can drill down into the
  // real transactions behind it. focusType ∈ category|subscription|goal|income;
  // focusKey is the entity's name (null for income). Null on legacy rows.
  focusType String?
  focusKey  String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BankStatement {
  id         String   @id @default(cuid())
  userId     String
  filename   String
  fileType   String
  status     String   @default("pending")
  txCount    Int      @default(0)
  uploadedAt DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

// A saved budget-advisor chat thread. Ephemeral history is gone — each turn is
// persisted so a user can reopen and continue a past conversation. `title` is a
// short AI-generated summary of the opening question.
model AdvisorConversation {
  id        String   @id @default(cuid())
  userId    String
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AdvisorMessage[]

  @@index([userId, updatedAt])
}

// One turn in an advisor conversation. `sources` holds the grounded reference
// records (AdvisorSource[]) the answer drew on, as JSON. userId is denormalized
// for ownership checks without a join.
model AdvisorMessage {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  role           String // "user" | "assistant"
  content        String
  sources        Json?
  createdAt      DateTime @default(now())

  conversation AdvisorConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

// One AI generation "job" (a chat turn, its title, or an insights run) with the
// token usage and derived USD cost. Written server-side after a successful call
// (lib/db/ai-usage), so failures/cached returns record nothing. Used only for
// internal usage/cost tracking (the /dev/usage page) — never user-facing.
model AiUsageEvent {
  id                       String   @id @default(cuid())
  userId                   String
  kind                     String // "advisor" | "advisor_title" | "insights"
  model                    String
  inputTokens              Int      @default(0)
  outputTokens             Int      @default(0)
  cacheReadInputTokens     Int      @default(0)
  cacheCreationInputTokens Int      @default(0)
  costUsd                  Float    @default(0)
  conversationId           String? // links an advisor turn to its chat (null for insights)
  createdAt                DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([kind, createdAt])
}

// Durable log of processed Stripe webhook events. `id` is the Stripe event id,
// so an insert doubling as the idempotency guard (Stripe delivers at-least-once
// and retries): if the row already exists, we've handled it — skip. Also a
// monitoring trail of every billing event we acted on.
model StripeEvent {
  id          String   @id // Stripe event id (evt_...)
  type        String
  userId      String? // resolved target user, when known
  payload     Json
  createdAt   DateTime @default(now())

  @@index([type, createdAt])
  @@index([userId, createdAt])
}
